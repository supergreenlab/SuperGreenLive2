FROM golang:1.22

RUN apt-get update && \
    apt-get install -y libmagickwand-7.q16-dev
COPY assets /usr/local/share/appbackend
COPY static /usr/local/share/appbackend_static

COPY bin/libcamera-streamer /usr/local/bin/libcamera-streamer
COPY bin/usbcam-streamer /usr/local/bin/usbcam-streamer
COPY bin/libcamera-still /usr/bin/libcamera-still

RUN go install github.com/air-verse/air@latest
RUN git config --global url.'ssh://git@github.com/'.insteadOf https://github.com/

RUN mkdir ~/.ssh
RUN echo "Host *\n   StrictHostKeyChecking no\n   UserKnownHostsFile=/dev/null" >> ~/.ssh/config

RUN mkdir /app
WORKDIR /app

EXPOSE 8081
ENTRYPOINT ["/bin/sh", "-c", "chmod 600 /root/.ssh/id_rsa && /go/bin/air"]
